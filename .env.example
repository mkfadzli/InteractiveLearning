# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Required for AI lesson enrichment (stage 2). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Python executable (use "python" on Windows, "python3" on macOS/Linux)
IL_PYTHON=python

# Optional: override where uploaded PDFs and course.json are stored
# IL_JOBS_DIR=C:\path\to\jobs
